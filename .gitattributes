# Auto detect text files and normalize line endings
* text=auto

# Explicit text file types
*.cs     text
*.csproj text
*.sln    text
*.config text
*.json   text
*.xml    text
*.xaml   text

# Binaries should not be diffed
*.dll    binary
*.exe    binary
*.pdb    binary
*.nupkg  binary
*.zip    binary

# Optional: force LF for scripts
*.sh     text eol=lf
*.ps1    text eol=crlf